{
	"name": "purplelint",
	"version": "0.5.0",
	"description": "Purpose-driven architecture linting protocol. Agent-agnostic. Open spec.",
	"type": "module",
	"bin": {
		"purplelint": "./dist/cli/index.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": ["dist", "presets", "templates", "README.md", "LICENSE"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"architecture",
		"lint",
		"linter",
		"clean-architecture",
		"code-quality",
		"ai-lint",
		"purpose-driven",
		"agent-agnostic"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/room821/purplelint"
	},
	"author": "Room821 <contact@room821.com>",
	"license": "MIT",
	"dependencies": {
		"@clack/prompts": "^0.8.0",
		"fast-glob": "^3.3.0",
		"simple-git": "^3.25.0",
		"yaml": "^2.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^20.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.5.0",
		"vitest": "^2.0.0"
	},
	"engines": {
		"node": ">=18"
	}
}
